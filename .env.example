# =============================================================================
# Quantum Market Scanner — example environment file
# =============================================================================
# Copy this file to `.env` and fill in the values you want to override.
# Every variable is optional — the scanner ships with sensible defaults and
# will fall back to free public providers (Yahoo Finance, Stooq, CoinGecko)
# without any keys.
# =============================================================================

# ---- Server -----------------------------------------------------------------
# Host/port uvicorn binds to.  Defaults match start.sh / start.bat.
# HOST=0.0.0.0
# PORT=8001

# ---- Optional provider API keys --------------------------------------------
# Finnhub — supplemental stock quotes (free tier: 60 req/min).
# Get a key at https://finnhub.io/
# FINNHUB_API_KEY=

# CoinGecko Pro — much higher rate limits for the crypto catalog refresh.
# Free tier works but throttles heavily; Pro unlocks the full 6,000+ coin
# ranked universe.  Get a key at https://www.coingecko.com/en/api/pricing
# COINGECKO_API_KEY=

# ---- Scan loop tuning (advanced) -------------------------------------------
# Symbols per batch.  Larger batches = higher throughput but slower response
# to universe changes.  Defaults are conservative.
# SNAPSHOT_BATCH_LIMIT_STOCKS=100
# SNAPSHOT_BATCH_LIMIT_CRYPTO=50

# Parallel batch workers per market.  2 is a good balance for a laptop.
# SNAPSHOT_PARALLEL_WORKERS=2

# Crypto stays idle unless the user viewed the crypto tab in the last N
# seconds.  Bumps HTTP budget toward the stock scanner otherwise.
# MARKET_ACTIVITY_TTL=600

# Watchdog: only trip if NO batch has completed for this many seconds.
# SNAPSHOT_WATCHDOG_STALL_S=600

# ---- Feature flags ----------------------------------------------------------
# Two-pass scoring (cheap pass + full-depth pass on top N%).  Set to 0 to
# force full-depth on every symbol (slower but more thorough).
# MRD_TWO_PASS_SCORING=1
# MRD_FULL_SCORE_TOP_PCT=30

# ---- Data directory --------------------------------------------------------
# Where cache files live.  Defaults to ./data relative to the repo root.
# APP_DATA_DIR=./data
